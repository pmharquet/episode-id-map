# ─────────────────────────────────────────────────────────────────────────────
# episode-id-map : variables d'environnement (copier vers .env et remplir)
# ─────────────────────────────────────────────────────────────────────────────

# --- TMDB (The Movie Database) ---
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3

# --- TheTVDB ---
TVDB_API_KEY=
TVDB_PIN=
TVDB_BASE_URL=https://api4.thetvdb.com/v4

# --- SIMKL ---
SIMKL_CLIENT_ID=
SIMKL_BASE_URL=https://api.simkl.com

# --- Jikan (MyAnimeList) ---
JIKAN_BASE_URL=https://api.jikan.moe/v4

# --- AniDB (httpapi) ---
ANIDB_CLIENT=
ANIDB_CLIENTVER=
ANIDB_BASE_URL=http://api.anidb.net:9001/httpapi

# --- PostgreSQL (dev local en Docker ; cible Supabase) ---
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=episode_id_map
POSTGRES_PORT=5432
# Connexion depuis l'hôte (python local). Dans Docker, l'app utilise déjà l'hôte "db".
DATABASE_URL=postgresql://user:password@localhost:5432/episode_id_map
